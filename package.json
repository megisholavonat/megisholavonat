{
    "name": "mhonorepo",
    "private": true,
    "scripts": {
        "dev": "turbo dev",
        "generate:schema": "pnpm --filter api run generate-openapi",
        "generate:client": "pnpm --filter api-client run generate",
        "generate:api": "pnpm generate:schema && pnpm generate:client"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "turbo": "2.9.6"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "overrides": {
            "lightningcss": "1.30.1"
        },
        "onlyBuiltDependencies": [
            "@swc/core",
            "core-js",
            "sharp"
        ]
    }
}
